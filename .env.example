# AI Enterprise System - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# DATABASE CONNECTIONS
# ============================================================================

# MongoDB (unstructured data, documents, logs)
MONGODB_URL=mongodb://admin:password123@localhost:27017/enterprise?authSource=admin

# PostgreSQL (structured data, employees, finance, sales)
POSTGRESQL_URL=postgresql://enterprise_user:password123@localhost:5432/enterprise

# Redis (caching, sessions)
REDIS_URL=redis://localhost:6379

# RabbitMQ (message queue)
RABBITMQ_URL=amqp://admin:password123@localhost:5672/

# ============================================================================
# AI PROVIDER API KEYS
# ============================================================================

# OpenAI (GPT-4, embeddings)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic Claude (Claude 3.5 Sonnet, Claude 3 Opus)
# Get your key from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini (Gemini 2.0 Flash, Gemini 1.5 Pro)
# Get your key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# DeepSeek (cost-effective fallback)
# Get your key from: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...

# ============================================================================
# EXTERNAL INTEGRATIONS
# ============================================================================

# SendGrid (email sending)
SENDGRID_API_KEY=SG.xxxx

# Twilio (SMS notifications)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=xxxx

# Stripe (payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Salesforce (CRM integration)
SALESFORCE_CLIENT_ID=xxxx
SALESFORCE_CLIENT_SECRET=xxxx
SALESFORCE_ORG_URL=https://your-org.salesforce.com

# HubSpot (CRM/Marketing)
HUBSPOT_API_KEY=pat-xxxx

# ============================================================================
# SERVICE CONFIGURATION
# ============================================================================

# Orchestrator service URL
ORCHESTRATOR_URL=http://localhost:8000

# AI Decision Engine URL
AI_DECISION_ENGINE_URL=http://localhost:8009

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Sentry error tracking (optional)
SENTRY_DSN=https://xxxx@sentry.io/xxxx

# ============================================================================
# SECURITY
# ============================================================================

# JWT secret for token signing
JWT_SECRET=your-super-secret-key-change-in-production

# JWT expiration time (in seconds)
JWT_EXPIRATION=3600

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable debug mode (verbose logging)
DEBUG=false

# Enable AI provider health monitoring
AI_PROVIDER_HEALTH_CHECK=true

# ============================================================================
# PRODUCTION SETTINGS
# ============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# API rate limits
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Maximum request timeout (seconds)
REQUEST_TIMEOUT=30
